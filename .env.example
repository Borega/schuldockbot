# Schuldockbot compose/runtime environment skeleton.
# Replace placeholder values with real credentials before long-running production use.
# Do not commit real secrets; keep this file token-safe and example-only.

# Required runtime source URLs (must be valid http(s) URLs with non-root paths).
SCHULDOCKBOT_SOURCE_JSON_URL=https://schuldock.hamburg/wp-json/schuldock/v1/issues
SCHULDOCKBOT_SOURCE_HTML_URL=https://schuldock.hamburg/aktuelle-meldungen

# Required persistent SQLite path (mounted via compose volume).
SCHULDOCKBOT_STATE_DB_PATH=/var/lib/schuldockbot/state.db

# Required Nextcloud Talk credentials.
# Room token must be URL-safe and must not include '/'.
SCHULDOCKBOT_TALK_BASE_URL=https://nextcloud.example
SCHULDOCKBOT_TALK_ROOM_TOKEN=roomToken123
SCHULDOCKBOT_TALK_USERNAME=bot-user
SCHULDOCKBOT_TALK_APP_PASSWORD=replace-with-app-password

# Optional runtime tuning defaults (safe baseline for long-running polling).
SCHULDOCKBOT_POLL_INTERVAL_SECONDS=600
SCHULDOCKBOT_RETRY_MAX_ATTEMPTS=3
SCHULDOCKBOT_RETRY_BACKOFF_SECONDS=30
SCHULDOCKBOT_SQLITE_TIMEOUT_SECONDS=5
SCHULDOCKBOT_TALK_TIMEOUT_SECONDS=10
